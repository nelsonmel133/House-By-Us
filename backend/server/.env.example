# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (MySQL 8.0+) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=hbu_app
DB_PASSWORD=changeme
DB_NAME=house_by_us

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_at_least_32_random_chars

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Bucket region — af-south-1 (Cape Town) is nearest to Zimbabwe
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=house-by-us-media
# CloudFront distribution URL or direct S3 URL (no trailing slash)
# e.g. https://d1234abcdef.cloudfront.net  OR  https://house-by-us-media.s3.af-south-1.amazonaws.com
MEDIA_BASE_URL=https://your-cloudfront-or-s3-url

# ── App ───────────────────────────────────────────────────────────────────────
# URL of the React client (used for CORS origin + OAuth redirect)
CLIENT_URL=http://localhost:5173

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for landlord bank detail encryption.
# MUST be exactly 64 hex characters (= 32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_char_string_generated_by_openssl

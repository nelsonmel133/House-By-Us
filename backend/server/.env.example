# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (MySQL) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=hbu_app
DB_PASSWORD=changeme
DB_NAME=house_by_us

# ── Session ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_hex_string_min_32_chars

# ── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=house-by-us-media
MEDIA_BASE_URL=https://house-by-us-media.s3.af-south-1.amazonaws.com

# ── Client ──────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Encryption ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars / 32 bytes)
ENCRYPTION_KEY=replace_with_64_char_hex_string_exactly_32_bytes_long_here

# ── API ──────────────────────────────────────────────────────────────────────
# Base URL of the backend API (no /trpc suffix — the mobile client appends it)
# For local dev with Expo Go on a physical device, use your LAN IP:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:4000
# For the emulator: http://10.0.2.2:4000 (Android) or http://localhost:4000 (iOS)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ── Google Maps ──────────────────────────────────────────────────────────────
# Replace these placeholders in mobile/app.json too — they are read at build time
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=YOUR_IOS_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=YOUR_ANDROID_GOOGLE_MAPS_API_KEY

# ── EAS ──────────────────────────────────────────────────────────────────────
# Replace in mobile/app.json → extra.eas.projectId after running `eas init`
EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID

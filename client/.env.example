# ── API ──────────────────────────────────────────────────────────────────────
# URL of the running backend server (no trailing slash)
# Development: http://localhost:4000/trpc
# Production:  https://api.housebyus.co.zw/trpc
VITE_API_URL=http://localhost:4000/trpc

# ── Map (Leaflet uses OpenStreetMap tiles by default — no key needed) ────────
# If you switch to Mapbox or Google Maps, add the key here:
# VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxx

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" to render mock data instead of hitting the real API
# Useful for frontend-only development without a running backend
VITE_USE_MOCK_DATA=false

# ── Firebase Authentication ──────────────────────────────────────────────────
# 1. Go to https://console.firebase.google.com and create a project (or reuse one)
# 2. Project settings → General → "Your apps" → Add app → Web (</>) 
#    Copy the config values it gives you into the fields below
# 3. Authentication → Sign-in method → enable "Google" and "Email/Password"
# 4. Sign in to the app with vimbaidhoro@gmail.com (via Google or by creating an
#    email/password account with that exact address) to get admin access to
#    /dashboard/admin — the account is checked by email, not by a Firebase role.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
